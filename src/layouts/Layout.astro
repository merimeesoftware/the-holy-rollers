---
/**
 * Holy Rollers Painting Co. - Base Layout
 * Uses the design system with Tailwind CSS
 */

interface Props {
  title: string;
  description?: string;
  image?: string;
  page?: string;
}

const { 
  title, 
  description = "Professional painting services in Strongsville, Ohio. Quality interior and exterior painting by Holy Rollers Painting Co.",
  image = "/og-image.jpg",
  page = "home"
} = Astro.props;

const siteName = "Holy Rollers Painting Co.";
const siteUrl = "https://holyrollerspainting.com";
const fullTitle = `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/${page}`} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content={siteName} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`${siteUrl}/${page}`} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <title>{fullTitle}</title>
  </head>
  
  <body class="font-sans text-dark bg-white antialiased">
    <!-- Skip to main content link for accessibility -->
    <a 
      href="#main-content" 
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg"
    >
      Skip to main content
    </a>
    
    <!-- Navigation (to be customized per page) -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-light transition-all duration-300" id="header">
      <nav class="container-lg flex items-center justify-between h-16 md:h-20">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-lg bg-primary flex items-center justify-center transition-transform duration-300 group-hover:scale-105">
            <span class="text-white font-montserrat font-bold text-lg md:text-xl">HR</span>
          </div>
          <div class="hidden sm:block">
            <span class="font-montserrat font-bold text-dark text-sm md:text-base leading-tight">
              Holy Rollers<br />
              <span class="text-secondary text-xs">Painting Co.</span>
            </span>
          </div>
        </a>
        
        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center gap-8">
          <a href="/" class="text-dark hover:text-primary transition-colors duration-300 font-medium">Home</a>
          <a href="/services" class="text-dark hover:text-primary transition-colors duration-300 font-medium">Services</a>
          <a href="/portfolio" class="text-dark hover:text-primary transition-colors duration-300 font-medium">Portfolio</a>
          <a href="/about" class="text-dark hover:text-primary transition-colors duration-300 font-medium">About</a>
          <a href="/contact" class="btn btn-primary text-sm">Get a Quote</a>
        </div>
        
        <!-- Mobile Menu Button -->
        <button 
          class="md:hidden p-2 text-dark hover:text-primary transition-colors"
          aria-label="Toggle menu"
          id="mobile-menu-btn"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>
      
      <!-- Mobile Menu (hidden by default) -->
      <div class="md:hidden hidden bg-white border-t border-light" id="mobile-menu">
        <div class="container-lg py-4 space-y-4">
          <a href="/" class="block text-dark hover:text-primary transition-colors font-medium py-2">Home</a>
          <a href="/services" class="block text-dark hover:text-primary transition-colors font-medium py-2">Services</a>
          <a href="/portfolio" class="block text-dark hover:text-primary transition-colors font-medium py-2">Portfolio</a>
          <a href="/about" class="block text-dark hover:text-primary transition-colors font-medium py-2">About</a>
          <a href="/contact" class="block btn btn-primary text-center mt-4">Get a Quote</a>
        </div>
      </div>
    </header>
    
    <!-- Main Content -->
    <main id="main-content" class="pt-16 md:pt-20">
      <slot />
    </main>
    
    <!-- Footer -->
    <footer class="bg-dark text-white py-12 md:py-16">
      <div class="container-lg">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
          <!-- Company Info -->
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-lg bg-primary flex items-center justify-center">
                <span class="text-white font-montserrat font-bold text-xl">HR</span>
              </div>
              <div>
                <span class="font-montserrat font-bold text-white">Holy Rollers</span>
                <p class="text-light text-sm">Painting Co.</p>
              </div>
            </div>
            <p class="text-light text-sm leading-relaxed">
              Professional painting services in Strongsville, Ohio. Quality interior and exterior painting for residential and commercial properties.
            </p>
          </div>
          
          <!-- Quick Links -->
          <div>
            <h4 class="font-montserrat font-semibold text-white mb-4">Quick Links</h4>
            <ul class="space-y-2">
              <li><a href="/" class="text-light hover:text-white transition-colors">Home</a></li>
              <li><a href="/services" class="text-light hover:text-white transition-colors">Services</a></li>
              <li><a href="/portfolio" class="text-light hover:text-white transition-colors">Portfolio</a></li>
              <li><a href="/about" class="text-light hover:text-white transition-colors">About Us</a></li>
              <li><a href="/contact" class="text-light hover:text-white transition-colors">Contact</a></li>
            </ul>
          </div>
          
          <!-- Services -->
          <div>
            <h4 class="font-montserrat font-semibold text-white mb-4">Services</h4>
            <ul class="space-y-2">
              <li><a href="/services#interior" class="text-light hover:text-white transition-colors">Interior Painting</a></li>
              <li><a href="/services#exterior" class="text-light hover:text-white transition-colors">Exterior Painting</a></li>
              <li><a href="/services#commercial" class="text-light hover:text-white transition-colors">Commercial Painting</a></li>
              <li><a href="/services#cabinet" class="text-light hover:text-white transition-colors">Cabinet Refinishing</a></li>
              <li><a href="/services#deck" class="text-light hover:text-white transition-colors">Deck & Fence</a></li>
            </ul>
          </div>
          
          <!-- Contact Info -->
          <div>
            <h4 class="font-montserrat font-semibold text-white mb-4">Contact Us</h4>
            <ul class="space-y-3 text-light">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Strongsville, Ohio</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href="tel:+1234567890" class="hover:text-white transition-colors">(234) 567-890</a>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:info@holyrollerspainting.com" class="hover:text-white transition-colors">info@holyrollerspainting.com</a>
              </li>
            </ul>
          </div>
        </div>
        
        <!-- Copyright -->
        <div class="border-t border-dark-200 mt-12 pt-8 text-center">
          <p class="text-light text-sm">
            &copy; {new Date().getFullYear()} Holy Rollers Painting Co. All rights reserved.
          </p>
        </div>
      </div>
    </footer>
    
    <!-- Mobile Menu Script -->
    <script>
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
