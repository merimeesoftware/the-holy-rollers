---
export interface NavItem {
  label: string;
  href: string;
}

export interface Props {
  companyName?: string;
  tagline?: string;
  email?: string;
  phone?: string;
  address?: string;
  navItems?: NavItem[];
  facebookUrl?: string;
  copyrightYear?: number;
}

const {
  companyName = "The Holy Roller Painting Co.",
  tagline = "Your Local Prayerful Painters",
  email = "holyrollerpainters@gmail.com",
  phone = "440-623-5336",
  address = "Strongsville, Ohio",
  navItems = [
    { label: "Home", href: "#" },
    { label: "Services", href: "#services" },
    { label: "Portfolio", href: "#portfolio" },
    { label: "About", href: "#about" },
    { label: "Contact", href: "#contact" },
  ],
  facebookUrl = "https://www.facebook.com",
  copyrightYear = new Date().getFullYear()
} = Astro.props;
---

<footer class="bg-[#20242f] text-white pt-16 pb-8" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Company Info -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-flex items-center space-x-3 mb-4" aria-label="The Holy Rollers - Home">
          <img
            src="/images/logo.png"
            alt="The Holy Roller Painting Co. Logo"
            class="h-16 w-16 object-contain rounded-full bg-white p-1"
            width="64"
            height="64"
          />
          <span class="text-xl font-bold">{companyName}</span>
        </a>
        <p class="text-gray-400 mb-6 max-w-md">
          {tagline}. Professional interior and exterior painting services with over 20 years of experience. Serving Strongsville and surrounding areas.
        </p>
        
        <!-- Social Links -->
        <div class="flex space-x-4">
          <a
            href={facebookUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-[#116DFF] hover:bg-[#0a5acc] rounded-full flex items-center justify-center transition-colors duration-200"
            aria-label="Follow us on Facebook (opens in new tab)"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold mb-4">Quick Links</h3>
        <ul class="space-y-3">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-gray-400 hover:text-[#116DFF] transition-colors duration-200"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-bold mb-4">Contact Us</h3>
        <ul class="space-y-4">
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-[#116DFF] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${phone.replace(/\D/g, '')}`} class="text-gray-400 hover:text-[#116DFF] transition-colors duration-200">
              {phone}
            </a>
          </li>
          
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-[#116DFF] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${email}`} class="text-gray-400 hover:text-[#116DFF] transition-colors duration-200">
              {email}
            </a>
          </li>
          
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-[#116DFF] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-gray-400">
              {address}
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-700 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-500 text-sm text-center md:text-left">
          © {copyrightYear} {companyName}. All rights reserved.
        </p>
        
        <div class="flex items-center space-x-2 text-gray-500 text-sm">
          <span>Built with</span>
          <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
          </svg>
          <span>for quality painting</span>
        </div>
      </div>
    </div>
  </div>
</footer>
