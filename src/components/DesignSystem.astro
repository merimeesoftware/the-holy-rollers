/* ============================================
   BUTTON COMPONENTS
   ============================================ */

/**
 * Primary Button
 * Used for main CTAs and primary actions
 */
export const buttonPrimary = (attributes = {}) => {
  const { href, onClick, children, className = '', ...props } = attributes;
  
  const baseClasses = 'btn btn-primary inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-roboto-bold text-sm uppercase tracking-wider transition-all duration-300 hover:bg-primary-dark hover:shadow-primary focus:ring-primary active:scale-95';
  
  if (href) {
    return `<a href="${href}" class="${baseClasses} ${className}">${children}</a>`;
  }
  
  return `<button class="${baseClasses} ${className}" onclick="${onClick || ''}">${children}</button>`;
};

/**
 * Secondary Button
 * Used for secondary actions
 */
export const buttonSecondary = (attributes = {}) => {
  const { href, onClick, children, className = '' } = attributes;
  
  const baseClasses = 'btn btn-secondary inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-roboto-bold text-sm uppercase tracking-wider transition-all duration-300 hover:bg-dark focus:ring-secondary active:scale-95';
  
  if (href) {
    return `<a href="${href}" class="${baseClasses} ${className}">${children}</a>`;
  }
  
  return `<button class="${baseClasses} ${className}">${children}</button>`;
};

