---
export interface Props {
  title?: string;
  ownerName?: string;
  ownerImage?: string;
  ownerAlt?: string;
  description?: string;
}

const {
  title = "About Us",
  ownerName = "Paul Koopman",
  ownerImage = "/images/about-owner.jpg",
  ownerAlt = "Paul Koopman - Owner of Holy Rollers Painting Company",
  description = "I am a seasoned professional with over two decades of experience in the painting industry, having previously served as a youth minister. Our company specializes in both interior and exterior painting services, catering to clients in the local area. We take great pride in our work and approach each project with a prayerful mindset, providing unparalleled attention to detail and customer satisfaction."
} = Astro.props;
---

<section id="about" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image Section -->
      <div class="relative order-2 lg:order-1">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <img
            src={ownerImage}
            alt={ownerAlt}
            class="w-full h-auto object-cover aspect-square max-w-md mx-auto"
            loading="lazy"
          />
        </div>
        <!-- Decorative element -->
        <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-[#116DFF] rounded-2xl -z-10 opacity-20"></div>
        <div class="absolute -top-6 -left-6 w-24 h-24 bg-[#20242f] rounded-2xl -z-10"></div>
      </div>

      <!-- Content Section -->
      <div class="order-1 lg:order-2">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#20242f] mb-6">
          {title}
        </h2>
        
        <div class="w-24 h-1 bg-[#116DFF] rounded-full mb-8"></div>
        
        <h3 class="text-2xl font-bold text-[#116DFF] mb-4">
          The Holy Rollers
        </h3>
        
        <p class="text-[#54597c] text-lg leading-relaxed mb-6">
          {description}
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 mt-8 pt-8 border-t border-gray-200">
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold text-[#20242f]">20+</div>
            <div class="text-sm text-[#54597c] mt-1">Years Experience</div>
          </div>
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold text-[#20242f]">1000+</div>
            <div class="text-sm text-[#54597c] mt-1">Projects Completed</div>
          </div>
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold text-[#20242f]">100%</div>
            <div class="text-sm text-[#54597c] mt-1">Satisfaction</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
