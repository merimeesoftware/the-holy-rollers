---
interface Props {
  size?: 'small' | 'medium' | 'large';
  className?: string;
}

const { size = 'medium', className = '' } = Astro.props;

const sizeClasses = {
  small: 'w-16 h-16',
  medium: 'w-24 h-24',
  large: 'w-32 h-32'
};
---

<div class={`inline-block ${sizeClasses[size]} ${className}`}>
  <a href="/" class="block w-full h-full">
    <img 
      src="/images/logo.png"
      alt="Logo for the Holy Rollers in Strongsville Ohio"
      class="w-full h-full object-contain"
      width="100"
      height="100"
    />
  </a>
</div>