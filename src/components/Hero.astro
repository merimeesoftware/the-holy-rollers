---
export interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  phoneNumber?: string;
  backgroundImage?: string;
}

const {
  title = "Your Local Prayerful Painters",
  subtitle = "Professional interior & exterior painting services with 20+ years of experience",
  ctaText = "Get a Free Estimate",
  ctaLink = "#contact",
  phoneNumber = "440-623-5336",
  backgroundImage = "https://static.wixstatic.com/media/b2a22f_8a117e3e9d374015aea3eb06681ead71~mv2.jpg/v1/fill/w_1280,h_830,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/b2a22f_8a117e3e9d374015aea3eb06681ead71~mv2.jpg"
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-cover bg-center bg-no-repeat" style={`background-image: linear-gradient(rgba(32, 36, 47, 0.7), rgba(32, 36, 47, 0.5)), url('${backgroundImage}')`}>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#20242f]/90"></div>
  
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 tracking-tight font-sans">
      {title}
    </h1>
    
    <p class="text-lg sm:text-xl md:text-2xl text-gray-200 mb-10 max-w-2xl mx-auto font-light">
      {subtitle}
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href={ctaLink}
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-[#116DFF] hover:bg-[#0a5acc] rounded-md transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1 w-full sm:w-auto"
        aria-label={`${ctaText} - Opens contact form`}
      >
        {ctaText}
      </a>
      
      <a
        href={`tel:${phoneNumber.replace(/\D/g, '')}`}
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white hover:bg-white hover:text-[#20242f] rounded-md transition-all duration-300 w-full sm:w-auto"
        aria-label={`Call us at ${phoneNumber}`}
      >
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.44 16.91c-.35.79-1.03 1.4-1.87 1.66-1.18.37-2.42.22-3.49-.46l-.91-.58c-.79-.5-1.61-.88-2.46-1.14-.53-.16-1.09-.08-1.59.21l-1.42.83c-.83.49-1.82.49-2.65 0l-.83-.83c-.49-.49-.49-1.28 0-1.77l.83-1.42c.29-.5.37-1.06.21-1.59-.26-.85-.64-1.67-1.14-2.46l-.58-.91c-.68-1.07-.83-2.31-.46-3.49.26-.84.87-1.52 1.66-1.87l1.18-.37c.79-.25 1.43-.02 1.92.49l.83.83c.49.49.74 1.17.49 1.96-.18.56.02 1.17.49 1.64l.91 1.18c.08.11.18.2.29.26l.79.49c.17.11.31.26.4.44l.49.83c.14.24.14.53 0 .77l-.37.74c-.11.22-.11.49 0 .71l.58 1.18c.18.37.55.58.94.58l.83-.37c.39-.18.79-.09 1.14.23l1.42 1.18c.62.52.62 1.51 0 2.03l-.83 1.42c-.35.32-.54.8-.54 1.31v1.18c0 .87.7 1.57 1.57 1.57h.37c.51 0 .99-.22 1.31-.54l1.42-1.42c.32-.35.41-.75.23-1.14l-.37-.83c-.11-.22-.08-.47.08-.65l.49-.79c.18-.29.26-.63.23-.98l-.08-1.13c-.03-.41.14-.81.46-1.1l.83-.83c.51-.49.74-1.17.49-1.92l-.37-1.18z"/>
        </svg>
        Call Today
      </a>
    </div>
  </div>
  
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
</section>
