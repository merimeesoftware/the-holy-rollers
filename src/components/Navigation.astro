---
export interface NavItem {
  label: string;
  href: string;
}

export interface Props {
  logoSrc?: string;
  logoAlt?: string;
  navItems?: NavItem[];
}

const {
  logoSrc = "/images/logo.png",
  logoAlt = "The Holy Roller Painting Co. Logo",
  navItems = [
    { label: "HOME", href: "#" },
    { label: "SERVICES", href: "#services" },
    { label: "PORTFOLIO", href: "#portfolio" },
  ]
} = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#20242f]/95 backdrop-blur-md shadow-lg" role="banner">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3 group" aria-label="The Holy Rollers - Home">
        <img
          src={logoSrc}
          alt={logoAlt}
          class="h-12 w-12 object-contain rounded-full bg-white p-1 transition-transform duration-300 group-hover:scale-110"
          width="48"
          height="48"
        />
        <span class="text-white font-bold text-lg md:text-xl hidden sm:block">
          Holy Rollers
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-white/90 hover:text-[#116DFF] font-medium uppercase tracking-wider text-sm transition-colors duration-200 relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-[#116DFF] after:transition-all after:duration-300 hover:after:w-full"
          >
            {item.label}
          </a>
        ))}
        <a
          href="#contact"
          class="bg-[#116DFF] hover:bg-[#0a5acc] text-white px-5 py-2.5 rounded-md font-semibold transition-all duration-200 shadow-md hover:shadow-lg"
        >
          Get Estimate
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="md:hidden p-2 text-white hover:text-[#116DFF] transition-colors duration-200"
        aria-label="Open menu"
        aria-expanded="false"
        id="mobile-menu-btn"
      >
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div
      class="md:hidden hidden absolute top-full left-0 right-0 bg-[#20242f]/98 backdrop-blur-md border-t border-gray-700"
      id="mobile-menu"
      role="navigation"
      aria-label="Mobile navigation"
    >
      <div class="px-4 py-6 space-y-4">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="block text-white/90 hover:text-[#116DFF] font-medium uppercase tracking-wider py-2 transition-colors duration-200"
          >
            {item.label}
          </a>
        ))}
        <a
          href="#contact"
          class="block bg-[#116DFF] hover:bg-[#0a5acc] text-white px-5 py-3 rounded-md font-semibold text-center transition-all duration-200 mt-4"
        >
          Get Free Estimate
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
      
      // Update button icon
      const svg = menuBtn.querySelector('svg');
      if (svg) {
        if (!isExpanded) {
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />';
        } else {
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
        }
      }
    });

    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        menuBtn.querySelector('svg')!.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
      });
    });
  }
</script>
