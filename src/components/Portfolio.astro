---

<section id="portfolio" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#20242f] mb-4">
        {title}
      </h2>
      <div class="w-24 h-1 bg-[#116DFF] mx-auto rounded-full"></div>
      <p class="mt-4 text-[#54597c] max-w-2xl mx-auto">
        Take a look at some of our recent painting projects. Each job is completed with the same attention to detail and quality craftsmanship.
      </p>
    </div>

    <!-- Masonry-style grid -->
    <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4" id="portfolio-grid">
      {items.slice(0, 8).map((item, index) => (
        <div class="break-inside-avoid group relative overflow-hidden rounded-lg shadow-md cursor-pointer">
          <img
            src={item.src}
            alt={item.alt}
            title={item.title}
            class="w-full h-auto object-cover transform group-hover:scale-110 transition-transform duration-500"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
            <div class="p-4">
              <p class="text-white font-semibold text-sm">{item.title}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Load More Button -->
    <div class="text-center mt-12">
      <button
        type="button"
        id="load-more-btn"
        class="inline-flex items-center px-8 py-3 bg-[#20242f] text-white font-semibold rounded-md hover:bg-[#116DFF] transition-colors duration-300"
        aria-label="Load more portfolio items"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Load More
      </button>
    </div>
  </div>
</section>

<script define:vars={{ items }}>
  const allItems = items;
  const initialCount = 8;
  let currentCount = initialCount;
  const grid = document.getElementById('portfolio-grid');
  const loadMoreBtn = document.getElementById('load-more-btn');

  function createPortfolioItem(item, index) {
    const div = document.createElement('div');
    div.className = 'break-inside-avoid group relative overflow-hidden rounded-lg shadow-md cursor-pointer';
    div.innerHTML = `
      <img
        src="${item.src}"
        alt="${item.alt}"
        title="${item.title}"
        class="w-full h-auto object-cover transform group-hover:scale-110 transition-transform duration-500"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
        <div class="p-4">
          <p class="text-white font-semibold text-sm">${item.title}</p>
        </div>
      </div>
    `;
    return div;
  }

  if (loadMoreBtn && grid) {
    loadMoreBtn.addEventListener('click', () => {
      const nextItems = allItems.slice(currentCount, currentCount + 4);
      
      nextItems.forEach((item, index) => {
        const newItem = createPortfolioItem(item, currentCount + index);
        grid.appendChild(newItem);
      });
      
      currentCount += nextItems.length;
      
      // Hide button if all items loaded
      if (currentCount >= allItems.length) {
        loadMoreBtn.style.display = 'none';
      }
    });
  }
</script>
