---

<section id="portfolio" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#20242f] mb-4">
        {title}
      </h2>
      <div class="w-24 h-1 bg-[#116DFF] mx-auto rounded-full"></div>
      <p class="mt-4 text-[#54597c] max-w-2xl mx-auto">
        Take a look at some of our recent painting projects. Each job is completed with the same attention to detail and quality craftsmanship.
      </p>
    </div>

    <!-- Masonry-style grid -->
    <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4">
      {items.map((item, index) => (
        <div class="break-inside-avoid group relative overflow-hidden rounded-lg shadow-md cursor-pointer">
          <img
            src={item.src}
            alt={item.alt}
            title={item.title}
            class="w-full h-auto object-cover transform group-hover:scale-110 transition-transform duration-500"
            loading={index < 8 ? "eager" : "lazy"}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
            <div class="p-4">
              <p class="text-white font-semibold text-sm">{item.title}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
